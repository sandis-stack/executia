{
  "cleanUrls": true,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/execution$",
      "dest": "/public/execution.html"
    },
    {
      "src": "^/request$",
      "dest": "/public/request.html"
    },
    {
      "src": "^/demo$",
      "dest": "/public/demo.html"
    },
    {
      "src": "^/dashboard$",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "^/financial$",
      "dest": "/public/financial.html"
    },
    {
      "src": "^/status$",
      "dest": "/public/status.html"
    },
    {
      "src": "^/protocol$",
      "dest": "/public/protocol.html"
    },
    {
      "src": "^/institutional$",
      "dest": "/public/institutional.html"
    },
    {
      "src": "^/global\\.css$",
      "dest": "/public/global.css"
    },
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1"
    }
  ]
}